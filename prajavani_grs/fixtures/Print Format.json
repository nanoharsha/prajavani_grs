[
 {
  "name": "Prajavani Receipt",
  "doctype": "Print Format",
  "doc_type": "Prajavani Attendance",
  "module": "GRS",
  "print_format_type": "Jinja",
  "custom_format": 1,
  "standard": "No",
  "disabled": 0,
  "creation": "2026-03-12 00:00:00",
  "modified": "2026-03-12 00:00:00",
  "modified_by": "Administrator",
  "owner": "Administrator",
  "html": "<style>\n  .pr { font-family: Arial, sans-serif; max-width: 750px; margin: 0 auto; padding: 24px; }\n  .pr-hdr { text-align: center; border-bottom: 3px double #1a56db; padding-bottom: 12px; margin-bottom: 16px; }\n  .pr-hdr h2 { color: #1a56db; font-size: 18px; margin: 0; }\n  .pr-hdr p  { color: #666; font-size: 12px; margin: 4px 0 0; }\n  .pr-meta { display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; font-size: 12px; background: #f0f4ff; padding: 8px 12px; border-radius: 4px; margin-bottom: 16px; }\n  .pr-section { margin-bottom: 14px; }\n  .pr-section h3 { font-size: 13px; font-weight: bold; color: #333; border-bottom: 1px solid #ddd; padding-bottom: 4px; margin: 0 0 8px; }\n  .pr-table { width: 100%; font-size: 12px; border-collapse: collapse; }\n  .pr-table td { padding: 4px 8px; vertical-align: top; }\n  .pr-table td:first-child { color: #666; width: 32%; font-weight: bold; }\n  .pr-box { border: 1px solid #ddd; border-radius: 4px; padding: 10px; min-height: 55px; font-size: 12px; background: #fafafa; white-space: pre-wrap; }\n  .pr-sign { display: flex; justify-content: space-between; margin-top: 36px; }\n  .pr-sign-box { text-align: center; width: 42%; }\n  .pr-sign-line { border-top: 1px solid #333; padding-top: 6px; font-size: 11px; color: #444; }\n  .pr-footer { text-align: center; margin-top: 16px; padding-top: 10px; border-top: 1px solid #ddd; font-size: 10px; color: #aaa; }\n</style>\n<div class=\"pr\">\n  <div class=\"pr-hdr\">\n    <h2>&#127963; Prajavani GRS &mdash; Attendance Receipt</h2>\n    <p>Government of Telangana &middot; Grievance Redressal System</p>\n  </div>\n\n  <div class=\"pr-meta\">\n    <span><strong>Receipt No:</strong> {{ doc.name }}</span>\n    <span><strong>Level:</strong> {{ doc.prajavani_level }} Prajavani</span>\n    <span><strong>Date:</strong> {{ doc.prajavani_date }}</span>\n    <span><strong>Venue:</strong> {{ doc.location }}</span>\n  </div>\n\n  {% set g = frappe.get_doc(\"Grievance\", doc.grievance) %}\n  <div class=\"pr-section\">\n    <h3>Grievance Details</h3>\n    <table class=\"pr-table\">\n      <tr><td>Registration No</td><td><strong>{{ g.registration_no or g.name }}</strong></td></tr>\n      <tr><td>Citizen Name</td><td>{{ g.citizen_name }}</td></tr>\n      <tr><td>Department</td><td>{{ g.department }}</td></tr>\n      <tr><td>Category</td><td>{{ g.category }}</td></tr>\n      <tr><td>Current Status</td><td>{{ g.status }}</td></tr>\n      <tr><td>Gist of Grievance</td><td>{{ g.gist_of_grievance }}</td></tr>\n    </table>\n  </div>\n\n  <div class=\"pr-section\">\n    <h3>GRO Remarks / Order</h3>\n    <div class=\"pr-box\">{{ doc.gro_remarks or \"\u2014\" }}</div>\n  </div>\n\n  <div class=\"pr-section\">\n    <h3>Citizen Remarks</h3>\n    <div class=\"pr-box\">{{ doc.citizen_remarks or \"\u2014\" }}</div>\n  </div>\n\n  {% if not doc.citizen_present %}\n  <p style=\"font-size:12px; color:#c00;\"><strong>Note:</strong> Citizen was not present at this Prajavani.</p>\n  {% endif %}\n\n  <div class=\"pr-sign\">\n    <div class=\"pr-sign-box\">\n      <div style=\"height:45px;\"></div>\n      <div class=\"pr-sign-line\">\n        {% if doc.attending_officer_name %}{{ doc.attending_officer_name }}<br>{% endif %}\n        <span style=\"font-size:10px;\">Attending GRO Officer</span>\n      </div>\n    </div>\n    <div class=\"pr-sign-box\">\n      <div style=\"height:45px;\"></div>\n      <div class=\"pr-sign-line\">\n        {{ g.citizen_name }}<br>\n        <span style=\"font-size:10px;\">Citizen / Representative</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"pr-footer\">\n    Receipt No: {{ doc.name }} &nbsp;|&nbsp; System-generated receipt &nbsp;|&nbsp; Prajavani GRS &middot; Government of Telangana\n  </div>\n</div>"
 }
]
